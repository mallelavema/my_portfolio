# Local environment file example.
# Copy this file to .env and provide your own local values.
# Never commit .env to version control.

# VITE_GEMINI_API_KEY: Local API key for any client-side or Vite-powered integration.
# Access it in the app via import.meta.env.VITE_GEMINI_API_KEY.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_DISABLE_HMR: Set to true to disable hot module reload in local development.
VITE_DISABLE_HMR="false"
